@model HealthManagement.Models.ExerciseLog

@{
    ViewData["Title"] = "Exercise Entry Details";
}

<h2>@ViewData["Title"]</h2>

<div>
    <h4>ExerciseLog</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Exercise</dt>
        <dd class="col-sm-10">@Model.ExerciseName</dd>

        <dt class="col-sm-2">Duration (min)</dt>
        <dd class="col-sm-10">@Model.DurationMinutes</dd>

        <dt class="col-sm-2">Calories Burned</dt>
        <dd class="col-sm-10">@Model.CaloriesBurned</dd>

        <dt class="col-sm-2">MET Value</dt>
        <dd class="col-sm-10">@Model.MetValue</dd>

        <dt class="col-sm-2">Intensity</dt>
        <dd class="col-sm-10">@Model.Intensity</dd>

        <dt class="col-sm-2">Logged</dt>
        <dd class="col-sm-10">@Model.DateLogged.ToLocalTime().ToString("g")</dd>
    </dl>
</div>

<p>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to list</a>
</p>