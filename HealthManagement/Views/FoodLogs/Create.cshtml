@model HealthManagement.Models.FoodLog

@{
    ViewData["Title"] = "Add Food Entry";
}

<h2>@ViewData["Title"]</h2>

<div class="card mb-3">
    <div class="card-body">
        <h5 class="card-title">AI Nutrient Extraction</h5>
        <div class="mb-3">
            <label for="foodDescription" class="form-label">Food Description</label>
            <textarea id="foodDescription" class="form-control" rows="3" placeholder="e.g. grilled chicken breast with rice and broccoli"></textarea>
            <button type="button" id="analyzeTextBtn" class="btn btn-outline-primary mt-2">Analyze Text</button>
        </div>
        <div class="mb-3">
            <label for="mealImage" class="form-label">Meal Image</label>
            <input id="mealImage" type="file" class="form-control" accept="image/*" />
            <button type="button" id="analyzeImageBtn" class="btn btn-outline-primary mt-2">Analyze Image</button>
        </div>
        <div id="aiStatus" class="text-muted small"></div>
    </div>
</div>

<form asp-action="Create" method="post">
    <div class="form-group">
        <label asp-for="FoodName"></label>
        <div class="position-relative">
            <input asp-for="FoodName" class="form-control" autocomplete="off" />
            <div id="foodNameSuggestions" class="list-group position-absolute w-100 d-none" style="z-index: 1050; max-height: 220px; overflow-y: auto;"></div>
        </div>
        <span asp-validation-for="FoodName" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Calories"></label>
        <input asp-for="Calories" class="form-control" />
        <span asp-validation-for="Calories" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Carbs"></label>
        <input asp-for="Carbs" class="form-control" />
        <span asp-validation-for="Carbs" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Protein"></label>
        <input asp-for="Protein" class="form-control" />
        <span asp-validation-for="Protein" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Fat"></label>
        <input asp-for="Fat" class="form-control" />
        <span asp-validation-for="Fat" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Micronutrients"></label>
        <input asp-for="Micronutrients" class="form-control" />
        <span asp-validation-for="Micronutrients" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
        const antiForgeryToken = tokenInput ? tokenInput.value : '';
        const statusEl = document.getElementById('aiStatus');
        const foodNameInput = document.getElementById('FoodName');
        const foodNameSuggestions = document.getElementById('foodNameSuggestions');
        const suggestionsUrl = '@Url.Action("Suggestions", "FoodLogs")';
        const foodDetailsUrl = '@Url.Action("FoodDetails", "FoodLogs")';
        let suggestionTimer = null;
        let activeSuggestionRequest = null;
        let activeSuggestionItems = [];
        let activeSuggestionIndex = -1;
        let lastAutoFilledFoodName = '';

        function updateFormFields(data) {
            const set = (name, value) => {
                const el = document.querySelector(`[name="${name}"]`);
                if (el && value !== undefined && value !== null) {
                    el.value = value;
                }
            };

            set('FoodName', data.foodName);
            set('Calories', data.calories);
            set('Carbs', data.carbs);
            set('Protein', data.protein);
            set('Fat', data.fat);
            if (data.micronutrients) {
                const micronutrientsValue = typeof data.micronutrients === 'string'
                    ? data.micronutrients
                    : JSON.stringify(data.micronutrients);
                set('Micronutrients', micronutrientsValue);
            }
        }

        async function postForm(url, formData) {
            const response = await fetch(url, {
                method: 'POST',
                body: formData,
                headers: {
                    'RequestVerificationToken': antiForgeryToken
                }
            });

            if (!response.ok) {
                const err = await response.json().catch(() => ({ message: 'AI analysis failed.' }));
                throw new Error(err.message || 'AI analysis failed.');
            }

            return response.json();
        }

        function renderFoodSuggestions(items) {
            foodNameSuggestions.innerHTML = '';
            activeSuggestionItems = items;
            activeSuggestionIndex = -1;

            if (!items || items.length === 0) {
                foodNameSuggestions.classList.add('d-none');
                return;
            }

            items.forEach((item, index) => {
                const suggestionButton = document.createElement('button');
                suggestionButton.type = 'button';
                suggestionButton.className = 'list-group-item list-group-item-action';
                suggestionButton.textContent = item;
                suggestionButton.dataset.index = index;
                suggestionButton.addEventListener('mousedown', e => {
                    // Prevent blur so click can complete selection.
                    e.preventDefault();
                });
                suggestionButton.addEventListener('click', () => {
                    selectSuggestion(item);
                });
                foodNameSuggestions.appendChild(suggestionButton);
            });

            foodNameSuggestions.classList.remove('d-none');
        }

        function hideSuggestions() {
            foodNameSuggestions.classList.add('d-none');
            activeSuggestionIndex = -1;
        }

        function highlightSuggestion(index) {
            const suggestionButtons = foodNameSuggestions.querySelectorAll('button[data-index]');
            suggestionButtons.forEach(button => button.classList.remove('active'));

            if (index >= 0 && index < suggestionButtons.length) {
                suggestionButtons[index].classList.add('active');
                suggestionButtons[index].scrollIntoView({ block: 'nearest' });
            }
        }

        async function autoFillFoodDetailsByName(selectedFoodName) {
            if (!selectedFoodName || selectedFoodName.length < 2) {
                return;
            }

            if (selectedFoodName.toLowerCase() === lastAutoFilledFoodName.toLowerCase()) {
                return;
            }

            try {
                const response = await fetch(`${foodDetailsUrl}?foodName=${encodeURIComponent(selectedFoodName)}`);
                if (!response.ok) {
                    return;
                }

                const data = await response.json();
                updateFormFields(data);
                lastAutoFilledFoodName = selectedFoodName;
                statusEl.textContent = 'Nutrition details auto-filled from previous entry.';
            } catch {
                // Keep the form usable even if suggestions lookup fails.
            }
        }

        function selectSuggestion(selectedFoodName) {
            foodNameInput.value = selectedFoodName;
            hideSuggestions();
            autoFillFoodDetailsByName(selectedFoodName);
        }

        if (foodNameInput && foodNameSuggestions) {
            foodNameInput.addEventListener('input', () => {
                const term = foodNameInput.value.trim();
                lastAutoFilledFoodName = '';

                if (suggestionTimer) {
                    clearTimeout(suggestionTimer);
                }

                if (activeSuggestionRequest) {
                    activeSuggestionRequest.abort();
                    activeSuggestionRequest = null;
                }

                if (term.length < 2) {
                    renderFoodSuggestions([]);
                    return;
                }

                suggestionTimer = setTimeout(async () => {
                    try {
                        activeSuggestionRequest = new AbortController();
                        const signal = activeSuggestionRequest.signal;
                        const response = await fetch(`${suggestionsUrl}?term=${encodeURIComponent(term)}`, { signal });
                        if (!response.ok) {
                            renderFoodSuggestions([]);
                            return;
                        }

                        const items = await response.json();
                        renderFoodSuggestions(Array.isArray(items) ? items : []);
                    } catch (error) {
                        if (error && error.name !== 'AbortError') {
                            renderFoodSuggestions([]);
                        }
                    } finally {
                        activeSuggestionRequest = null;
                    }
                }, 220);
            });

            foodNameInput.addEventListener('keydown', e => {
                if (foodNameSuggestions.classList.contains('d-none') || activeSuggestionItems.length === 0) {
                    return;
                }

                if (e.key === 'ArrowDown') {
                    e.preventDefault();
                    activeSuggestionIndex = Math.min(activeSuggestionIndex + 1, activeSuggestionItems.length - 1);
                    highlightSuggestion(activeSuggestionIndex);
                } else if (e.key === 'ArrowUp') {
                    e.preventDefault();
                    activeSuggestionIndex = Math.max(activeSuggestionIndex - 1, 0);
                    highlightSuggestion(activeSuggestionIndex);
                } else if (e.key === 'Enter') {
                    if (activeSuggestionIndex >= 0 && activeSuggestionIndex < activeSuggestionItems.length) {
                        e.preventDefault();
                        selectSuggestion(activeSuggestionItems[activeSuggestionIndex]);
                    }
                } else if (e.key === 'Escape') {
                    hideSuggestions();
                }
            });

            foodNameInput.addEventListener('blur', () => {
                setTimeout(() => hideSuggestions(), 120);
            });
        }

        document.getElementById('analyzeTextBtn').addEventListener('click', async () => {
            try {
                const description = document.getElementById('foodDescription').value;
                statusEl.textContent = 'Analyzing text...';
                const formData = new FormData();
                formData.append('description', description);
                const data = await postForm('@Url.Action("AnalyzeText", "FoodLogs")', formData);
                updateFormFields(data);
                statusEl.textContent = 'Text analysis complete. Fields auto-filled.';
            } catch (error) {
                statusEl.textContent = error.message;
            }
        });

        document.getElementById('analyzeImageBtn').addEventListener('click', async () => {
            try {
                const imageInput = document.getElementById('mealImage');
                if (!imageInput.files || imageInput.files.length === 0) {
                    statusEl.textContent = 'Please choose an image first.';
                    return;
                }

                statusEl.textContent = 'Analyzing image...';
                const formData = new FormData();
                formData.append('mealImage', imageInput.files[0]);
                const data = await postForm('@Url.Action("AnalyzeImage", "FoodLogs")', formData);
                updateFormFields(data);
                statusEl.textContent = 'Image analysis complete. Fields auto-filled.';
            } catch (error) {
                statusEl.textContent = error.message;
            }
        });
    </script>
}